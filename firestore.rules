rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Admin check based on collection lookup OR bootstrapped email
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == 'rautshambhuraut747@gmail.com' && request.auth.token.email_verified == true)
      );
    }

    // 1. Links Collection
    match /links/{linkId} {
      function isValidLink(data) {
        return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
               data.org is string && data.org.size() <= 100 &&
               data.url is string && data.url.size() <= 1000 &&
               (data.notificationUrl == null || (data.notificationUrl is string && data.notificationUrl.size() <= 1000)) &&
               data.category in ["jobs", "results", "admit", "admission", "scheme", "cert", "state", "central"] &&
               data.createdAt == (resource == null ? request.time : resource.data.createdAt);
      }

      allow read: if true; // Public access for the portal
      
      allow create: if isAdmin() && 
                    isValidId(linkId) && 
                    isValidLink(incoming()) &&
                    incoming().keys().hasAll(['title', 'org', 'url', 'category', 'createdAt']) &&
                    incoming().createdAt == request.time;

      allow update: if isAdmin() && 
                    isValidLink(incoming()) &&
                    (
                      // Allow updates to content but keep metadata stable if needed
                      incoming().updatedAt == request.time &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'org', 'description', 'url', 'category', 'tags', 'updatedAt'])
                    );

      allow delete: if isAdmin();
    }

    // 2. Admins Collection
    match /admins/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if false; // Managed via console or super-admin scripts (if added)
    }
  }
}
